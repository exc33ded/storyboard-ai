# --- Text LLM (director, research, prompts) ---
# Uses the OpenAI SDK. Point TEXT_BASE_URL at any OpenAI-compatible endpoint:
# Ollama (http://localhost:11434/v1), LM Studio (http://localhost:1234/v1),
# DeepSeek (https://api.deepseek.com), NVIDIA NIM, OpenRouter, Groq, or plain
# OpenAI (leave TEXT_BASE_URL unset).
TEXT_API_KEY="your-api-key-here"
# TEXT_BASE_URL="http://localhost:11434/v1"
TEXT_MODEL="gpt-4o-mini"

# --- Vision LLM (narration polish, segmentation object-ID, reference-image
# verification) — only needed if your TEXT_MODEL has no vision support (e.g.
# DeepSeek). Groq's free tier serves a real vision model at no cost:
# https://console.groq.com/keys
VISION_API_KEY="your-groq-api-key-here"
VISION_BASE_URL="https://api.groq.com/openai/v1"
VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# --- Image generation: FLUX.2 [klein] 4B via Hugging Face Inference API ---
HF_API_KEY="your-huggingface-token-here"
# IMAGE_GEN_MODEL="black-forest-labs/FLUX.2-klein-4B"

# --- TTS: Kokoro (local, open-source, no key needed) ---
# KOKORO_LANG_CODE="a"
# KOKORO_VOICE_SPEAKER_ONE="af_heart"
# KOKORO_VOICE_SPEAKER_TWO="am_puck"

# --- Subtitles: faster-whisper (local, open-source, no key needed) ---
# WHISPER_MODEL_SIZE="base"

# --- SearXNG (optional, self-hosted metasearch — free, no rate limits) ---
# Used for web research and reference-image search when set; falls back to
# DuckDuckGo/Wikipedia otherwise. Setup:
#   docker run -d --name searxng -p 8888:8080 searxng/searxng
#   then in the container's /etc/searxng/settings.yml enable JSON output:
#     search:
#       formats: [html, json]
#   and restart the container.
# SEARXNG_URL="http://localhost:8888"

# --- Gemini API Key (only used for optional Veo video gen) ---
GEMINI_API_KEY="your-google-api-key-here"

# Set to TRUE if using Vertex AI, or FALSE to use Google Developer API (default)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
